pipeline {
    agent any

    stages {
        stage('Setup') {
            steps {
                deleteDir()
                sh '''
                    git clone -b test/arnaud https://github.com/inmanta/inmanta-core.git
                    python3.13 -m venv venv
                    . venv/bin/activate
                    pip install -U pip
                    pip install -e './inmanta-core[dev]' -r ./inmanta-core/requirements.txt pytest pytest-asyncio
                '''
            }
        }

        stage('Test') {
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    sh '''
                        . venv/bin/activate
                        cd inmanta-core
                        make ci-mypy
                    '''
                }
            }
        }
    }

    post {
        always {
            junit(
                testResults: 'inmanta-core/junit-mypy.xml',
                skipMarkingBuildUnstable: true,
                allowEmptyResults: true,
                skipMarkingStageUnstable: false
            )
        }
    }
}

